{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"scripts/log_prompt.ps1\"",
            "shell": "powershell",
            "timeout": 15,
            "statusMessage": "PROMPT_HISTORY 자동 기록 중..."
          }
        ]
      }
    ]
  }
}
